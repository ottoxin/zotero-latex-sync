# Copy this file to `.zotero.env` in your project root.

# Required: numeric Zotero user or group library ID
export ZOTERO_LIBRARY_ID=YOUR_NUMERIC_ID

# Optional: `user` or `group`
export ZOTERO_LIBRARY_TYPE=user

# Recommended: limit sync to the collection for one paper/project
export ZOTERO_COLLECTION_KEY=YOUR_COLLECTION_KEY

# Needed only for private libraries or private collections
# export ZOTERO_API_KEY=YOUR_API_KEY_IF_PRIVATE

# Optional: keep the default unless you need plain BibTeX
export ZOTERO_EXPORT_FORMAT=biblatex

# Optional: choose your local bibliography filename
export ZOTERO_BIB_FILE=references.bib
